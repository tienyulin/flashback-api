# flashback-api configuration. Copy to .env and fill in.
# Example upstream app (Oracle Flashback Recovery API).
# NOTE: docker compose does NOT strip inline "# comments" from .env values —
# keep comments on their own lines.

# true = in-memory mock; false = real Oracle (set ORACLE_* below)
MOCK_ORACLE=true
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
# empty = unauthenticated (dev)
FLASHBACK_API_KEY=
FRA_USAGE_THRESHOLD=85
