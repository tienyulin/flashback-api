{
  "components": {
    "schemas": {
      "CreateRestorePointRequest": {
        "description": "Body for POST /restore_points (spec §3).",
        "properties": {
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          },
          "guarantee": {
            "default": true,
            "title": "Guarantee",
            "type": "boolean"
          },
          "name": {
            "maxLength": 128,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "name"
        ],
        "title": "CreateRestorePointRequest",
        "type": "object"
      },
      "DatabaseTarget": {
        "description": "Exactly one of restore_point / scn / timestamp (spec §3 flashback/database).",
        "properties": {
          "restore_point": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Restore Point"
          },
          "scn": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scn"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          }
        },
        "title": "DatabaseTarget",
        "type": "object"
      },
      "FinalizeRequest": {
        "description": "Body for POST /flashback/database/finalize (irreversible; spec §3).",
        "properties": {
          "approval_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Approval Id"
          },
          "confirm": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confirm"
          },
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          }
        },
        "title": "FinalizeRequest",
        "type": "object"
      },
      "FlashbackDatabaseRequest": {
        "description": "Body for POST /flashback/database (irreversible; spec §3).",
        "properties": {
          "approval_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Approval Id"
          },
          "confirm": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Confirm"
          },
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          },
          "target": {
            "$ref": "#/components/schemas/DatabaseTarget"
          }
        },
        "required": [
          "target"
        ],
        "title": "FlashbackDatabaseRequest",
        "type": "object"
      },
      "FlashbackDropRequest": {
        "description": "Body for POST /flashback/drop (spec §3).",
        "properties": {
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          },
          "owner": {
            "title": "Owner",
            "type": "string"
          },
          "rename_to": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Rename To"
          },
          "table_name": {
            "title": "Table Name",
            "type": "string"
          }
        },
        "required": [
          "owner",
          "table_name"
        ],
        "title": "FlashbackDropRequest",
        "type": "object"
      },
      "FlashbackTableRequest": {
        "description": "Body for POST /flashback/table (spec §3).",
        "properties": {
          "dry_run": {
            "default": true,
            "title": "Dry Run",
            "type": "boolean"
          },
          "enable_row_movement": {
            "default": false,
            "title": "Enable Row Movement",
            "type": "boolean"
          },
          "owner": {
            "title": "Owner",
            "type": "string"
          },
          "table_name": {
            "title": "Table Name",
            "type": "string"
          },
          "target": {
            "$ref": "#/components/schemas/FlashbackTarget"
          }
        },
        "required": [
          "owner",
          "table_name",
          "target"
        ],
        "title": "FlashbackTableRequest",
        "type": "object"
      },
      "FlashbackTarget": {
        "description": "Exactly one of scn / timestamp (spec §3 flashback/table).",
        "properties": {
          "scn": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Scn"
          },
          "timestamp": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Timestamp"
          }
        },
        "title": "FlashbackTarget",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "description": "API over DBA-SOP-014 (sop/oracle-flashback-recovery.md)",
    "title": "Oracle Flashback Recovery API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/audit/log": {
      "get": {
        "description": "Audit trail, newest first (SOP §8).",
        "operationId": "audit_log_audit_log_get",
        "parameters": [
          {
            "description": "回傳的稽核紀錄筆數上限（自動夾在 1-1000）",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 100,
              "description": "回傳的稽核紀錄筆數上限（自動夾在 1-1000）",
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "entries": [
                    {
                      "dry_run": true,
                      "operation": "flashback_table",
                      "operator": "dev",
                      "result": "dry_run",
                      "target": "HR.EMPLOYEES",
                      "timestamp": "2026-06-28T10:00:00"
                    }
                  ]
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "unexpected error"
                }
              }
            },
            "description": "伺服器內部錯誤（unexpected internal error）"
          }
        },
        "summary": "稽核軌跡，最新的排最前（SOP §8）"
      }
    },
    "/flashback/database": {
      "post": {
        "description": "IRREVERSIBLE: rewind the whole database (SOP §5, approval required).\nEnds in READ ONLY validation state; finalize with /flashback/database/finalize.",
        "operationId": "flashback_database_flashback_database_post",
        "parameters": [
          {
            "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlashbackDatabaseRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "checks": {
                    "P1_archivelog": {
                      "ok": true
                    }
                  },
                  "dry_run": true,
                  "estimated_flashback_size": "2GB",
                  "resolved_target_scn": 123000
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "Invalid or missing X-API-Key"
                }
              }
            },
            "description": "缺少或錯誤的 X-API-Key（啟用驗證時）"
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "restore point 'BEFORE_PATCH' does not exist — see GET /restore_points",
                  "error_code": "ORA-38780"
                }
              }
            },
            "description": "目標資源不存在（resource not found）"
          },
          "409": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "P1 violated: database is not in ARCHIVELOG mode"
                }
              }
            },
            "description": "SOP 前置條件未滿足或狀態衝突（precondition / state conflict）"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "428": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "irreversible operation requires confirm='I-UNDERSTAND-DATA-LOSS' and a non-empty approval_id (change-approval ticket)"
                }
              }
            },
            "description": "不可逆操作需 confirm token + approval_id（confirmation required）"
          }
        },
        "summary": "把整個資料庫回溯到誤操作之前的狀態，救回大規模誤刪／誤改（不可逆，需審批）"
      }
    },
    "/flashback/database/finalize": {
      "post": {
        "description": "IRREVERSIBLE: OPEN RESETLOGS after manual validation (SOP §5 steps 4-5).",
        "operationId": "finalize_database_flashback_database_finalize_post",
        "parameters": [
          {
            "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FinalizeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "dry_run": true,
                  "would_finalize_at_scn": 123456
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "Invalid or missing X-API-Key"
                }
              }
            },
            "description": "缺少或錯誤的 X-API-Key（啟用驗證時）"
          },
          "409": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "database state is OPEN — nothing to finalize (expected FLASHBACKED, i.e. read-only validation window)"
                }
              }
            },
            "description": "SOP 前置條件未滿足或狀態衝突（precondition / state conflict）"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "428": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "irreversible operation requires confirm='I-UNDERSTAND-DATA-LOSS' and a non-empty approval_id (change-approval ticket)"
                }
              }
            },
            "description": "不可逆操作需 confirm token + approval_id（confirmation required）"
          }
        },
        "summary": "人工驗證後正式套用資料庫回溯（OPEN RESETLOGS，不可逆）"
      }
    },
    "/flashback/drop": {
      "post": {
        "description": "Restore a dropped table from the recycle bin (SOP §4.2).",
        "operationId": "flashback_drop_flashback_drop_post",
        "parameters": [
          {
            "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlashbackDropRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "dry_run": true,
                  "restored_as": "EMPLOYEES",
                  "would_restore": {
                    "original_name": "EMPLOYEES"
                  }
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "Invalid or missing X-API-Key"
                }
              }
            },
            "description": "缺少或錯誤的 X-API-Key（啟用驗證時）"
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "HR.EMPLOYEES is not in the recycle bin (purged, or recyclebin=off)",
                  "error_code": "ORA-38305"
                }
              }
            },
            "description": "目標資源不存在（resource not found）"
          },
          "409": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "table HR.EMPLOYEES already exists — retry with rename_to",
                  "error_code": "ORA-38312"
                }
              }
            },
            "description": "SOP 前置條件未滿足或狀態衝突（precondition / state conflict）"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "從資源回收筒救回被誤刪（DROP）的整張資料表"
      }
    },
    "/flashback/status": {
      "get": {
        "description": "Aggregated precondition checks P1-P4 (SOP §2).",
        "operationId": "flashback_status_flashback_status_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "db_state": "OPEN",
                  "flashback_on": true,
                  "fra_usage_percent": 42.0,
                  "log_mode": "ARCHIVELOG",
                  "preconditions": {
                    "P1_archivelog": true,
                    "P2_flashback_on": true,
                    "P3_fra_space": true
                  }
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "unexpected error"
                }
              }
            },
            "description": "伺服器內部錯誤（unexpected internal error）"
          }
        },
        "summary": "彙總 DB 狀態與 P1-P3 前置條件快照（SOP §2）"
      }
    },
    "/flashback/table": {
      "post": {
        "description": "Rewind a table to a past SCN/timestamp (SOP §4.1). Reversible:\nresponse carries prior_scn for flashing back again.",
        "operationId": "flashback_table_flashback_table_post",
        "parameters": [
          {
            "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
            "in": "header",
            "name": "x-api-key",
            "required": false,
            "schema": {
              "default": "",
              "description": "操作者 API 金鑰（mutation 端點需要；啟用驗證時用於授權與稽核身分）",
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FlashbackTableRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "checks": {
                    "P1_archivelog": {
                      "ok": true
                    }
                  },
                  "dry_run": true,
                  "prior_scn": 123456
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "401": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "Invalid or missing X-API-Key"
                }
              }
            },
            "description": "缺少或錯誤的 X-API-Key（啟用驗證時）"
          },
          "404": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "table HR.EMPLOYEES not found"
                }
              }
            },
            "description": "目標資源不存在（resource not found）"
          },
          "409": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "P6 violated: HR.EMPLOYEES has ROW MOVEMENT disabled — retry with enable_row_movement=true",
                  "error_code": "ORA-08189"
                }
              }
            },
            "description": "SOP 前置條件未滿足或狀態衝突（precondition / state conflict）"
          },
          "422": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "target must contain exactly one of: scn, timestamp"
                }
              }
            },
            "description": "請求驗證失敗（request validation failed）"
          }
        },
        "summary": "把資料表回溯到過去的時間點或 SCN，救回被誤改、誤刪的資料列（可逆）"
      }
    },
    "/health": {
      "get": {
        "description": "Health check.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "status": "ok"
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "unexpected error"
                }
              }
            },
            "description": "伺服器內部錯誤（unexpected internal error）"
          }
        },
        "summary": "存活檢查（liveness probe）"
      }
    },
    "/recyclebin": {
      "get": {
        "description": "Recycle bin contents, newest drop first (SOP §4.2 step 1).",
        "operationId": "recyclebin_recyclebin_get",
        "parameters": [
          {
            "description": "只列出此 schema/owner 的項目（省略則全部）",
            "in": "query",
            "name": "owner",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "只列出此 schema/owner 的項目（省略則全部）",
              "title": "Owner"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "entries": [
                    {
                      "droptime": "2026-06-20:10:00:00",
                      "object_name": "BIN$abc==$0",
                      "original_name": "EMPLOYEES",
                      "owner": "HR"
                    }
                  ]
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "unexpected error"
                }
              }
            },
            "description": "伺服器內部錯誤（unexpected internal error）"
          }
        },
        "summary": "查詢資源回收筒中被刪除（DROP）的資料表，最近刪的排最前"
      }
    },
    "/restore_points": {
      "get": {
        "description": "Existing restore points ordered by SCN (SOP §3.2).",
        "operationId": "list_restore_points_restore_points_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "restore_points": [
                    {
                      "guarantee": true,
                      "name": "BEFORE_PATCH",
                      "scn": 123456,
                      "storage_size": 1048576,
                      "time": "2026-06-28:09:00:00"
                    }
                  ]
                },
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "500": {
            "content": {
              "application/json": {
                "example": {
                  "detail": "unexpected error"
                }
              }
            },
            "description": "伺服器內部錯誤（unexpected internal error）"
          }
        },
